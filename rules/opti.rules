rule "Opti ON"
  when

    Item Opti changed from OFF to ON

  then

    //executeCommandLine(Duration.ofSeconds(10), "/usr/bin/wakeonlan", "-i", "172.27.72.255", "90:b1:1c:91:25:7e")
    executeCommandLine(Duration.ofSeconds(10), "ssh", "root@ucg.bluetears.org", "etherwake", "90:b1:1c:91:25:7e")

end

rule "Opti OFF"
  when

    Item Opti changed from ON to OFF

  then

    //executeCommandLine(Duration.ofSeconds(10), "ssh", "root@opti.bluetears.org", "/sbin/shutdown", "-h", "now")
    executeCommandLine(Duration.ofSeconds(10), "ssh", "root@opti-10.bluetears.org", "/mnt/vintage/10baseT/10g-down.sh")

end
